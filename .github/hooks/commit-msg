#!/usr/bin/env bash
# Commit message hook for dotfiles project
set -euo pipefail

commit_msg_file="$1"
commit_msg=$(cat "$commit_msg_file")

# Colors for output
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Skip checks for merge commits
if echo "$commit_msg" | grep -q "^Merge "; then
    exit 0
fi

# Skip checks for revert commits
if echo "$commit_msg" | grep -q "^Revert "; then
    exit 0
fi

# Validate commit message format
echo "📝 Validating commit message format..."

# Check if commit message is not empty (after stripping comments)
if [ -z "$(echo "$commit_msg" | grep -v '^#' | head -1 | xargs)" ]; then
    echo -e "${RED}❌ Commit message cannot be empty${NC}"
    exit 1
fi

# Get the first line (subject)
subject=$(echo "$commit_msg" | head -1)

# Check subject line length (recommended: 50 chars, max: 72)
subject_length=${#subject}
if [ $subject_length -gt 72 ]; then
    echo -e "${RED}❌ Commit subject line too long ($subject_length chars). Keep it under 72 characters.${NC}"
    exit 1
elif [ $subject_length -gt 50 ]; then
    echo -e "${YELLOW}⚠️  Commit subject line is long ($subject_length chars). Consider keeping it under 50 characters.${NC}"
fi

# Check that subject doesn't end with a period
if echo "$subject" | grep -q '\.$'; then
    echo -e "${RED}❌ Commit subject should not end with a period${NC}"
    exit 1
fi

# Check for imperative mood (common verbs that should be imperative)
first_word=$(echo "$subject" | awk '{print tolower($1)}')
case "$first_word" in
    "added"|"adding"|"adds")
        echo -e "${YELLOW}⚠️  Use imperative mood: 'Add' instead of '$first_word'${NC}"
        ;;
    "fixed"|"fixing"|"fixes")
        echo -e "${YELLOW}⚠️  Use imperative mood: 'Fix' instead of '$first_word'${NC}"
        ;;
    "updated"|"updating"|"updates")
        echo -e "${YELLOW}⚠️  Use imperative mood: 'Update' instead of '$first_word'${NC}"
        ;;
    "removed"|"removing"|"removes")
        echo -e "${YELLOW}⚠️  Use imperative mood: 'Remove' instead of '$first_word'${NC}"
        ;;
    "changed"|"changing"|"changes")
        echo -e "${YELLOW}⚠️  Use imperative mood: 'Change' instead of '$first_word'${NC}"
        ;;
esac

# Suggest conventional commit format for dotfiles-specific changes
if echo "$subject" | grep -qE "(component|config|install|setup|dotfile)" && ! echo "$subject" | grep -qE "^(feat|fix|docs|style|refactor|test|chore):"; then
    echo -e "${YELLOW}💡 Consider using conventional commit format:${NC}"
    echo -e "${YELLOW}   feat: add new component${NC}"
    echo -e "${YELLOW}   fix: resolve installation issue${NC}"
    echo -e "${YELLOW}   docs: update component documentation${NC}"
    echo -e "${YELLOW}   refactor: improve component structure${NC}"
    echo -e "${YELLOW}   chore: update dependencies${NC}"
fi

echo "✅ Commit message format looks good!"
exit 0
