#!/usr/bin/env bash
# Pre-commit hook for dotfiles project
set -euo pipefail

echo "🔍 Running pre-commit checks..."

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Track if any checks fail
FAILED=0

# Function to print status
print_status() {
    if [ "$2" -eq 0 ]; then
        echo -e "${GREEN}✅ $1${NC}"
    else
        echo -e "${RED}❌ $1${NC}"
        FAILED=1
    fi
}

# Check 1: Validate shell scripts with shellcheck
echo "🐚 Checking shell scripts..."
if command -v shellcheck >/dev/null 2>&1; then
    # Find all shell scripts in src/
    shell_files=$(find src/ -name "*.sh" -type f 2>/dev/null || true)
    if [ -n "$shell_files" ]; then
        # shellcheck disable=SC2086
        if shellcheck $shell_files; then
            print_status "Shell script validation" 0
        else
            print_status "Shell script validation" 1
        fi
    else
        print_status "Shell script validation (no files found)" 0
    fi
else
    echo -e "${YELLOW}⚠️  shellcheck not installed, skipping shell script validation${NC}"
fi

# Check 2: Validate YAML files
echo "📄 Checking YAML files..."
yaml_files=$(find src/components/ -name "component.yml" -type f 2>/dev/null || true)
if [ -n "$yaml_files" ]; then
    yaml_valid=0
    while IFS= read -r file; do
        if command -v yq >/dev/null 2>&1; then
            if ! yq eval '.' "$file" >/dev/null 2>&1; then
                echo -e "${RED}❌ Invalid YAML: $file${NC}"
                yaml_valid=1
            fi
        elif command -v python3 >/dev/null 2>&1; then
            if ! python3 -c "import yaml; yaml.safe_load(open('$file'))" 2>/dev/null; then
                echo -e "${RED}❌ Invalid YAML: $file${NC}"
                yaml_valid=1
            fi
        fi
    done <<< "$yaml_files"
    print_status "YAML validation" $yaml_valid
else
    print_status "YAML validation (no files found)" 0
fi

# Check 3: Validate component structure
echo "🔧 Checking component structure..."
component_structure_valid=0
for component_dir in src/components/*/; do
    if [ -d "$component_dir" ]; then
        component_name=$(basename "$component_dir")

        # Check for required files
        if [ ! -f "$component_dir/component.yml" ]; then
            echo -e "${RED}❌ Missing component.yml in $component_name${NC}"
            component_structure_valid=1
        fi

        if [ ! -f "$component_dir/install.sh" ]; then
            echo -e "${RED}❌ Missing install.sh in $component_name${NC}"
            component_structure_valid=1
        fi

        # Check if install.sh is executable
        if [ -f "$component_dir/install.sh" ] && [ ! -x "$component_dir/install.sh" ]; then
            echo -e "${RED}❌ install.sh not executable in $component_name${NC}"
            component_structure_valid=1
        fi
    fi
done
print_status "Component structure validation" $component_structure_valid

# Check 4: Prevent committing sensitive files
echo "🔒 Checking for sensitive files..."
sensitive_patterns=(
    "*.key"
    "*.pem"
    "*.p12"
    "*.pfx"
    "*password*"
    "*secret*"
    "*.env"
    ".env.*"
)

sensitive_found=0
for pattern in "${sensitive_patterns[@]}"; do
    # Check staged files for sensitive patterns
    if git diff --cached --name-only | grep -i "$pattern" >/dev/null 2>&1; then
        echo -e "${RED}❌ Sensitive file pattern detected: $pattern${NC}"
        sensitive_found=1
    fi
done
print_status "Sensitive file check" $sensitive_found

# Check 5: Validate README.md links (basic check)
echo "📝 Checking README.md..."
readme_valid=0
if [ -f "README.md" ] && git diff --cached --name-only | grep -q "README.md"; then
    # Check for basic markdown syntax issues
    if grep -q '\[.*\](\s*\)' README.md; then
        echo -e "${RED}❌ Empty links found in README.md${NC}"
        readme_valid=1
    fi
fi
print_status "README.md validation" $readme_valid

# Summary
echo ""
if [ $FAILED -eq 0 ]; then
    echo -e "${GREEN}🎉 All pre-commit checks passed!${NC}"
    exit 0
else
    echo -e "${RED}💥 Some pre-commit checks failed. Please fix the issues above.${NC}"
    echo -e "${YELLOW}💡 You can skip these checks with: git commit --no-verify${NC}"
    exit 1
fi
